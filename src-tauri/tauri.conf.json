{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "SolonCode Studio",
    "version": "0.13.0",
    "identifier": "cn.duozai.soloncodestudio",
    "build": {
        "frontendDist": "../src"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "SolonCode Studio",
                "theme": "Light",
                "width": 1280,
                "height": 860,
                "minWidth": 1000,
                "minHeight": 700,
                "center": true,
                "resizable": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
        "category": "DeveloperTool",
        "shortDescription": "SolonCode Studio",
        "longDescription": "SolonCode Studio"
    }
}
